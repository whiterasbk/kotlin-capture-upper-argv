{
  "name": "Kotlin Compiler Plugin Dev Environment",
  "image": "mcr.microsoft.com/devcontainers/java:17-bullseye",

  "customizations": {
    "vscode": {
      "extensions": [
        "fwcd.kotlin",
        "vscjava.vscode-java-pack",
        "vscjava.vscode-gradle",
        "ms-azuretools.vscode-docker",
        "redhat.vscode-xml",
        "redhat.vscode-yaml"
      ]
    }
  },

  "mounts": [
    "source=${localEnv:HOME}/.gradle,target=/home/vscode/.gradle,type=bind"
  ],

  "containerEnv": {
    "GRADLE_USER_HOME": "/home/vscode/.gradle",
    "AUTO_PUBLISH_MAVEN_REPO": "false"
  },

  "postCreateCommand": "chmod +x gradlew && ./gradlew classes",

  "remoteUser": "vscode"
}